<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Owl Wedding</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Poppins:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Poppins', sans-serif;
      color: #333;
      background: #f6f3ef;
    }

    .container {
      width: 1200px;
      max-width: 95%;
      margin: auto;
    }

    h1, h2, h3 {
      font-family: 'Playfair Display', serif;
      font-weight: 600;
    }

    /* HERO */
    .hero {
      position: relative;
      height: 90vh;
      background: url("https://images.unsplash.com/photo-1522673607200-164d1b6ce486") center/cover no-repeat;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
    }

    .hero h1 {
      font-size: 4rem;
      font-weight: 400;
      letter-spacing: 2px;
    }

    /* STORY SECTION */
    .story {
      padding: 80px 0;
      display: flex;
      gap: 50px;
      align-items: center;
    }

    .story-text {
      flex: 1;
    }

    .story-text p {
      margin-top: 20px;
      line-height: 1.8;
      font-size: 0.95rem;
    }

    .story-images {
      flex: 1;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 15px;
    }

    .story-images img {
      width: 100%;
      border-radius: 10px;
      height: 180px;
      object-fit: cover;
    }

    /* SERVICES */
    .services {
      padding: 80px 0;
      text-align: center;
      background: linear-gradient(to bottom, #f6f3ef, #f1e4e8);
    }

    .services h2 {
      margin-bottom: 50px;
    }

    .service-item {
      margin-bottom: 60px;
    }

    .service-item img {
      width: 350px;
      height: 220px;
      object-fit: cover;
      border-radius: 12px;
      margin-bottom: 15px;
    }

    .service-item p {
      width: 60%;
      margin: auto;
      font-size: 0.9rem;
      line-height: 1.7;
    }

    /* GALLERY */
    .gallery {
      padding: 80px 0;
      text-align: center;
    }

    .gallery-grid {
      display: flex;
      justify-content: center;
      gap: 20px;
      margin-top: 40px;
    }

    .gallery-grid img {
      width: 300px;
      height: 350px;
      object-fit: cover;
      border-radius: 10px;
    }

    /* TESTIMONIALS */
    .testimonials {
      padding: 80px 0;
      text-align: center;
      background: #f6f3ef;
    }

    .testimonial-box {
      width: 60%;
      margin: 40px auto;
      font-style: italic;
      line-height: 1.8;
      font-size: 0.95rem;
    }

    /* FOOTER */
    footer {
      background: #345d3b;
      color: white;
      padding: 60px 0;
      text-align: center;
    }

    footer p {
      margin: 10px 0;
    }

    footer .socials {
      margin-top: 20px;
    }

    footer .socials a {
      margin: 0 10px;
      color: white;
      text-decoration: none;
      font-size: 1.2rem;
    }

    /* RESPONSIVE */
    @media (max-width: 992px) {
      .story {
        flex-direction: column;
      }

      .service-item p {
        width: 90%;
      }

      .gallery-grid {
        flex-direction: column;
        align-items: center;
      }
    }

  </style>
</head>
<body>

  <!-- HERO -->
  <section class="hero">
    <h1>We Capture Your Moments</h1>
  </section>

  <!-- STORY -->
  <section class="story container">
    <div class="story-text">
      <h2>Our Story</h2>
      <p>
        We are wedding storytellers passionate about capturing emotions,
        timeless romance, and authentic celebrations. Our journey started
        with a simple goal — to preserve love stories through artful imagery.
      </p>
      <p>
        Every couple is unique, and we ensure your wedding moments
        are transformed into memories you will cherish forever.
      </p>
    </div>
    <div class="story-images">
      <img src="https://images.unsplash.com/photo-1520854221256-17451cc331bf" alt="">
      <img src="https://images.unsplash.com/photo-1519741497674-611481863552" alt="">
      <img src="https://images.unsplash.com/photo-1529634806980-85c3dd6d34ac" alt="">
      <img src="https://images.unsplash.com/photo-1511285560929-80b456fea0bc" alt="">
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services">
    <div class="container">
      <h2>Services</h2>

      <div class="service-item">
        <img src="https://images.unsplash.com/photo-1520854221256-17451cc331bf" alt="">
        <h3>Intimate Wedding</h3>
        <p>Capturing emotional and private ceremonies with warmth and elegance.</p>
      </div>

      <div class="service-item">
        <img src="https://images.unsplash.com/photo-1519741497674-611481863552" alt="">
        <h3>Destination Wedding</h3>
        <p>Beautiful storytelling in breathtaking destinations around the world.</p>
      </div>

      <div class="service-item">
        <img src="https://images.unsplash.com/photo-1529634806980-85c3dd6d34ac" alt="">
        <h3>Luxury Wedding</h3>
        <p>Premium cinematic coverage designed for grand celebrations.</p>
      </div>

    </div>
  </section>

  <!-- GALLERY -->
  <section class="gallery container">
    <h2>Gallery</h2>
    <div class="gallery-grid">
      <img src="https://images.unsplash.com/photo-1511285560929-80b456fea0bc" alt="">
      <img src="https://images.unsplash.com/photo-1522673607200-164d1b6ce486" alt="">
      <img src="https://images.unsplash.com/photo-1519741497674-611481863552" alt="">
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="testimonials">
    <div class="container">
      <h2>Testimonials</h2>
      <div class="testimonial-box">
        "Owl Wedding beautifully captured every special moment of our big day.
        The photos were magical, emotional, and timeless."
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="container">
      <h3>Owl Wedding</h3>
      <p>Thiruvananthapuram, Kerala, India</p>
      <p>+91 98765 43210</p>
      <p>info@owlwedding.com</p>

      <div class="socials">
        <a href="#">Facebook</a>
        <a href="#">Instagram</a>
        <a href="#">WhatsApp</a>
      </div>
    </div>
  </footer>

</body>
</html>